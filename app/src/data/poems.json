  {
    "id": "poem-016",
    "title": "春夜喜雨",
    "author": "杜甫",
    "dynasty": "唐",
    "type": "诗",
    "content": [
      "好雨知时节",
      "当春乃发生",
      "随风潜入夜",
      "润物细无声",
      "野径云俱黑",
      "江船火独明",
      "晓看红湿处",
      "花重锦官城"
    ],
    "background": "杜甫在成都草堂逢春雨而作，以喜悦笔触写春雨润物的温柔。",
