FROM node:20-alpine AS base

# ---- Dependencies ----
FROM base AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --omit=dev

# ---- Build ----
FROM base AS build
WORKDIR /app

# Build-time vars (NEXT_PUBLIC_* MUST be set during build — they get inlined into client JS)
ARG NEXT_PUBLIC_SUPABASE_URL
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY
ARG NEXT_PUBLIC_WECHAT_APP_ID
ARG NEXT_PUBLIC_SPOTIFY_CLIENT_ID
ARG WECHAT_APP_SECRET
ARG ANTHROPIC_API_KEY
ARG OPENAI_API_KEY
ARG DEEPSEEK_API_KEY
ARG SUPABASE_SERVICE_ROLE_KEY
ARG SPOTIFY_CLIENT_SECRET
ARG NETEASE_API_BASE
# Non-prefixed vars for runtime server-side use (not inlined)
ARG SUPABASE_URL
ARG SUPABASE_ANON_KEY

ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY
ENV NEXT_PUBLIC_WECHAT_APP_ID=$NEXT_PUBLIC_WECHAT_APP_ID
ENV NEXT_PUBLIC_SPOTIFY_CLIENT_ID=$NEXT_PUBLIC_SPOTIFY_CLIENT_ID
ENV WECHAT_APP_SECRET=$WECHAT_APP_SECRET
ENV ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY
ENV OPENAI_API_KEY=$OPENAI_API_KEY
ENV DEEPSEEK_API_KEY=$DEEPSEEK_API_KEY
ENV SUPABASE_SERVICE_ROLE_KEY=$SUPABASE_SERVICE_ROLE_KEY
ENV SPOTIFY_CLIENT_SECRET=$SPOTIFY_CLIENT_SECRET
ENV NETEASE_API_BASE=$NETEASE_API_BASE
ENV SUPABASE_URL=$SUPABASE_URL
ENV SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY

COPY package.json package-lock.json ./
RUN npm ci
COPY . .
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

# ---- Runner ----
FROM base AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000

# Runtime env (server-side API routes and SSR can read these)
ARG NEXT_PUBLIC_SUPABASE_URL
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY
ARG NEXT_PUBLIC_WECHAT_APP_ID
ARG NEXT_PUBLIC_SPOTIFY_CLIENT_ID
ARG WECHAT_APP_SECRET
ARG ANTHROPIC_API_KEY
ARG OPENAI_API_KEY
ARG DEEPSEEK_API_KEY
ARG SUPABASE_SERVICE_ROLE_KEY
ARG SPOTIFY_CLIENT_SECRET
ARG NETEASE_API_BASE
# Non-prefixed vars for runtime server-side use (not inlined)
ARG SUPABASE_URL
ARG SUPABASE_ANON_KEY

ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY
ENV NEXT_PUBLIC_WECHAT_APP_ID=$NEXT_PUBLIC_WECHAT_APP_ID
ENV NEXT_PUBLIC_SPOTIFY_CLIENT_ID=$NEXT_PUBLIC_SPOTIFY_CLIENT_ID
ENV WECHAT_APP_SECRET=$WECHAT_APP_SECRET
ENV ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY
ENV OPENAI_API_KEY=$OPENAI_API_KEY
ENV DEEPSEEK_API_KEY=$DEEPSEEK_API_KEY
ENV SUPABASE_SERVICE_ROLE_KEY=$SUPABASE_SERVICE_ROLE_KEY
ENV SPOTIFY_CLIENT_SECRET=$SPOTIFY_CLIENT_SECRET
ENV NETEASE_API_BASE=$NETEASE_API_BASE
ENV SUPABASE_URL=$SUPABASE_URL
ENV SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

COPY --from=build /app/public ./public
COPY --from=build --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=build --chown=nextjs:nodejs /app/.next/static ./.next/static

USER nextjs
EXPOSE 3000
CMD ["node", "server.js"]
