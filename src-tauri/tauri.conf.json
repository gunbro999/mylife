{
  "$schema": "https://raw.githubusercontent.com/nickknapton12/tauri-docs/main/tauri-conf-schema.json",
  "productName": "浮生记",
  "version": "0.1.0",
  "identifier": "com.mylife.app",
  "build": {
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev --prefix app",
    "beforeBuildCommand": "npm run build --prefix app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "浮生记",
        "label": "main",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "浮生记",
      "menuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "installMode": "currentUser"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/gunbro999/mylife/releases/latest/download/latest.json"
      ],
      "pubkey": "PLACEHOLDER_PUBLIC_KEY",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
